# Twilio SMS credentials (get from twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Server
PORT=3000
NODE_ENV=production

# How often to check classes (in minutes)
CHECK_INTERVAL_MINUTES=1

# ASU Session Cookie (see README for how to get this)
ASU_SESSION_COOKIE=your_asu_session_cookie_here
